# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=platform
POSTGRES_USER=platform
POSTGRES_PASSWORD=

# Object storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=platform

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=

# Models
ANTHROPIC_API_KEY=
PLANNER_MODEL=
DEVELOPER_MODEL=

# Developer agent loop (card 08)
DEVELOPER_MAX_ITERATIONS=15
MAX_DEVELOPER_TOKENS_PER_TASK=200000
# Commands run in a fresh sandbox to install the target repo's deps (JSON list of argv
# lists). Default installs a pnpm/TS repo from its lockfile; set to [] to disable.
SANDBOX_SETUP_COMMANDS=[["pnpm", "install", "--frozen-lockfile"]]

# Platform services (real agents wire in only when these are set)
SANDBOX_URL=
VERIFIER_URL=
CONTEXT_PROVIDER_URL=

# MCP: Graphify and CRG
GRAPHIFY_MCP_URL=
CRG_MCP_URL=
